# Copie para `.env` na raiz e ajuste (nunca commite `.env`).
# Fase 0: valores de exemplo para desenvolvimento local.

# PostgreSQL (Docker Compose — ver docker-compose.yml)
POSTGRES_USER=loja
POSTGRES_PASSWORD=loja
POSTGRES_DB=loja_dev
# Porta no host (omissão no compose: 5433). Só precisa se quiser outra, ex.: 5432
# POSTGRES_HOST_PORT=5432

# API — SQLAlchemy sync (psycopg v3)
# Alembic / API a correr NO HOST contra o Postgres do Compose: use a porta publicada (omissão 5433).
# O contentor `backend` ignora isto e usa `postgres:5432` na rede interna.
DATABASE_URL=postgresql+psycopg://loja:loja@localhost:5433/loja_dev

# JWT (access token); use um segredo forte em produção
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# Frontend → backend (URL pública do browser; em Docker ver compose)
NEXT_PUBLIC_API_URL=http://localhost:8000
